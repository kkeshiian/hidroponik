{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "mqtt:start": "php artisan mqtt:subscribe",
        "mqtt:node": "node node-subscriber.js",
        "start:all": "concurrently -n web,vite,mqtt -c green,blue,yellow \"php artisan serve\" \"npm run dev\" \"php artisan mqtt:subscribe\"",
        "prod:mqtt:up": "pm2 start ecosystem.config.cjs --only hidroponik-mqtt --update-env",
        "prod:mqtt:restart": "pm2 restart hidroponik-mqtt --update-env",
        "prod:mqtt:logs": "pm2 logs hidroponik-mqtt",
        "prod:mqtt:down": "pm2 stop hidroponik-mqtt",
        "prod:mqtt:delete": "pm2 delete hidroponik-mqtt",
        "prod:mqtt:save": "pm2 save"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "autoprefixer": "^10.4.22",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "daisyui": "^5.5.5",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.5.6",
        "tailwindcss": "^4.1.17",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "dotenv": "^16.4.7",
        "mqtt": "^5.14.1",
        "mysql2": "^3.15.3"
    }
}
